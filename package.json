{
  "name": "midnight-medic",
  "version": "0.1.0",
  "description": "Environment diagnostic, version sync, and Compact linting CLI for Midnight Network developers.",
  "type": "module",
  "bin": {
    "midnight-medic": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --dts",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "midnight",
    "midnight-network",
    "compact",
    "zk",
    "devtools",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "glob": "^10.4.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  }
}
