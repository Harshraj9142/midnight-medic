{
  "name": "midnight-medic",
  "version": "0.1.0",
  "description": "Environment diagnostic, version sync, and Compact linting CLI for Midnight Network developers.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "midnight-medic": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --dts",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "midnight",
    "midnight-network",
    "compact",
    "zk",
    "zero-knowledge",
    "devtools",
    "cli",
    "diagnostics",
    "proof-server"
  ],
  "author": "Harshraj9142",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harshraj9142/midnight-medic.git"
  },
  "homepage": "https://github.com/Harshraj9142/midnight-medic#readme",
  "bugs": {
    "url": "https://github.com/Harshraj9142/midnight-medic/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "glob": "^10.4.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  }
}
